// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  name           String?
  email          String?        @unique
  hashedPassword String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  events         Event[]
  reviews        Review[]
  favorites      UserFavorite[]
  checkIns       CheckIn[]
  rsvps          EventRSVP[]
  following      UserFollow[] @relation("Follower")
  followers      UserFollow[] @relation("Following")
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("Follower",  fields: [followerId],  references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@map("user_follows")
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  location    String
  author      User     @relation(fields: [authorId], references: [id])
  authorId    String
  venues      Venue[]
}

model Venue {
  id      String  @id @default(cuid())
  name    String
  address String
  Event   Event?  @relation(fields: [eventId], references: [id])
  eventId String?
}

// OSM venue id stored as string — no FK into Venue table (venues come from OpenStreetMap live)
model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  venueId   String
  rating    Int      // 1–5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, venueId])
  @@map("reviews")
}

model UserFavorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  venueId   String
  createdAt DateTime @default(now())

  @@unique([userId, venueId])
  @@map("user_favorites")
}

model CheckIn {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  venueId   String
  createdAt DateTime @default(now())

  @@map("check_ins")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("newsletter_subscribers")
}

model EventRSVP {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId String // local curated event id (string key)

  createdAt DateTime @default(now())

  @@unique([userId, eventId])
  @@map("event_rsvps")
}
